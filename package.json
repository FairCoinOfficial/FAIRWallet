{
  "name": "fairwallet",
  "version": "1.0.0",
  "private": true,
  "description": "Lightweight SPV wallet for FairCoin",
  "author": "FairCoin <dev@fairco.in>",
  "license": "MIT",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "electron": "electron electron/main.js",
    "electron:build": "bun run export:web && electron-builder",
    "export:web": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "build:android": "eas build --platform android --profile preview",
    "build:android:local": "npx expo prebuild --platform android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@expo/vector-icons": "15.0.3",
    "@noble/hashes": "^1.7.1",
    "@noble/secp256k1": "^2.2.3",
    "@scure/bip32": "^1.6.2",
    "@scure/bip39": "^1.5.4",
    "bs58": "^6.0.0",
    "expo": "~55.0.0",
    "expo-camera": "~55.0.0",
    "expo-clipboard": "~55.0.0",
    "expo-crypto": "~55.0.0",
    "expo-linking": "~55.0.0",
    "expo-local-authentication": "^55.0.13",
    "expo-localization": "~55.0.0",
    "expo-router": "~55.0.0",
    "expo-secure-store": "~55.0.0",
    "expo-sqlite": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.10",
    "typescript": "^5.3.3"
  }
}
