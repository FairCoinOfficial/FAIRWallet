{
  "expo": {
    "name": "FAIRWallet",
    "slug": "fairwallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": ["fairwallet", "faircoin"],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1b1e09"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.fairco.wallet"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1b1e09"
      },
      "package": "in.fairco.wallet",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [{ "scheme": "faircoin" }],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-local-authentication",
      "expo-system-ui",
      ["expo-splash-screen", {
        "image": "./assets/icon.png",
        "imageWidth": 200,
        "backgroundColor": "#1b1e09"
      }],
      ["expo-camera", { "cameraPermission": "FAIRWallet needs camera access to scan QR codes." }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
